# 代理服务器监听端口
PORT=3000

# 自定义 Gemini Upstream API 基础地址 (可选项。用于国内中转、Cloudflare Workers 等自建反代，默认指向官方地址)
# 支持尾部带斜杠或不带斜杠，代理端会自动进行合并容错处理。
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# 交易 payload 日志保存的相对或绝对路径，默认当前运行目录下的 logs/ 目录
TRANSACTION_LOGS_DIR=logs

# 日志输出级别: error, warn, info, debug
LOG_LEVEL=debug

# Admin Viewer Credentials (format: username:password). If not set, admin routes are inaccessible.
ADMIN_CREDENTIALS=admin:supersecret
