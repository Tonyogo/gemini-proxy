# ==============================================================================
# Gemini Proxy Environment Configuration File Example
# ==============================================================================

# 代理服务器监听端口 (默认值: 3000)
PORT=3000

# 自定义 Gemini Upstream API 基础地址 (可选项。用于国内中转、Cloudflare Workers 等自建反代，默认指向官方地址)
# 支持尾部带斜杠或不带斜杠，代理端会自动进行合并容错与路径合并处理。
# 默认值: https://generativelanguage.googleapis.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# 交易 payload JSON 记录保存的相对或绝对目录。调试时可以使用，默认在当前目录下的 data/debug/ 下保存
# 默认值: logs (会合并至 data/debug 目录中进行管理)
TRANSACTION_LOGS_DIR=logs

# 控制台日志级别，支持的值有: error, warn, info, debug
# 默认值: info
LOG_LEVEL=info

# 运行环境，支持的值有: development, production, test
# 默认值: 无 (在生产中通常设置为 production，在测试中通常设置为 test)
NODE_ENV=development

# 是否在 Jest 单元测试执行期间开启详细的控制台日志输出 (true/false)
# 默认值: false
ENABLE_LOGS=false
